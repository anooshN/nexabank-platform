# ─────────────────────────────────────────────
# NexaBank Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

# JWT (must be at least 32 characters!)
JWT_SECRET=nexabank-super-secret-key-for-jwt-signing-must-be-256-bits-long

# Database passwords
DB_PASSWORD=nexabank123
REDIS_PASSWORD=nexabank_redis
MONGO_PASSWORD=nexabank123
RABBITMQ_PASSWORD=nexabank123

# ─── AI SERVICE (Required for fraud detection + chatbot) ───
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-your-openai-key-here

# ─── EMAIL (Required for transaction confirmations) ───
# Gmail: enable 2FA → App Passwords → create one
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── Optional: For production only ───
# KUBECONFIG (base64 encoded)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
